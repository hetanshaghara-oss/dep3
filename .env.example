# ============================================
# .env.example
# Copy this file to .env and fill your values
# NEVER upload .env to GitHub
# ============================================

# MongoDB Connection
# Get this from MongoDB Atlas dashboard
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/worldcup2026?retryWrites=true&w=majority

# Google Cloud & Gemini
# Get from Google Cloud Console (https://console.cloud.google.com)
GOOGLE_CLOUD_PROJECT=your-google-project-id
GEMINI_API_KEY=AQ.Ab8RN6KFEV82LMDne57C8IvbjYH8CWuGCnI1EulkvlxMON4Naw

# AI Platform Settings
# If using Gemini directly
AI_PLATFORM_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent
AI_PLATFORM_API_KEY=your-gemini-api-key

# Google Cloud Agent Builder (Vertex AI Search / Dialogflow CX)
GOOGLE_AGENT_ID=your-agent-id
GOOGLE_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./keys/google-key.json
USE_AGENT_BUILDER=true

# Server Configuration
PORT=3000
NODE_ENV=development

# Data File Path
ELO_DATA_FILE=./elo_ratings_wc2026.json

# Vercel Deployment (when deploying)
VERCEL_URL=https://your-project.vercel.app
